{
  "lastChangelogVersion": "0.80.2",
  "theme": "cyber-ui-dark",
  "packages": [
    "npm:pi-web-access",
    "npm:@tmustier/pi-usage-extension",
    "npm:@eko24ive/pi-ask",
    "git:github.com/22GNUs/pi-qoder-provider",
    "/Users/xinhua/Developer/pi-cyber-ui",
    "npm:@juicesharp/rpiv-todo",
    "npm:pi-dynamic-workflows"
  ],
  "defaultProvider": "qoder",
  "defaultModel": "gm51model",
  "defaultThinkingLevel": "high",
  "hideThinkingBlock": true,
  "terminal": {
    "showImages": false
  },
  "images": {
    "blockImages": false
  },
  "quietStartup": false,
  "compaction": {
    "enabled": true
  },
  "enabledModels": [
    "cf-codex/gpt-5.5",
    "qoder/ultimate",
    "qoder/gm51model",
    "qoder/kmodel-highspeed",
    "cf-codex/grok-composer-2.5-fast"
  ],
  "extensions": [
    "+extensions/pi-custom-providers/custom-provider-cf-packycode.ts",
    "+extensions/pi-custom-providers/custom-provider-cliproxyapi.ts"
  ],
  "transport": "auto",
  "rewind": {
    "silentCheckpoints": false,
    "retention": {
      "maxSnapshots": 100,
      "maxAgeDays": 1,
      "scanMode": "ancestor-only",
      "pinLabeledEntries": true,
      "startupBudgetMs": 100
    }
  }
}