{
  "lastChangelogVersion": "0.80.10",
  "theme": "cyber-ui-dark",
  "externalEditor": "nvim",
  "packages": [
    "npm:pi-web-access",
    "npm:@eko24ive/pi-ask",
    "npm:@juicesharp/rpiv-todo",
    "npm:@mohndoe/pi-atlas",
    "/Users/xinhua/Developer/pi-qoder-provider-inner",
    {
      "source": "git:github.com/router-for-me/pi-cliproxyapi-provider",
      "extensions": [
        "-extensions/tps.ts"
      ]
    },
    {
      "source": "/Users/xinhua/Developer/pi-cyber-ui",
      "themes": [
        "+themes/cyber-ui-dark.json"
      ],
      "extensions": [
        "+extensions/pi-cyber-ui/index.ts"
