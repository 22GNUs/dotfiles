{
  "lastChangelogVersion": "0.70.5",
  "theme": "cyber-ui-dark",
  "packages": [
    "npm:pi-cyber-ui@0.1.2",
    "npm:pi-web-access",
    "npm:pi-peon-ping",
    "npm:@plannotator/pi-extension",
    "npm:@sting8k/pi-vcc",
    "npm:pi-rtk-optimizer",
    "npm:@tmustier/pi-usage-extension",
    "npm:pi-caveman",
    "npm:@howaboua/pi-auto-trees",
    "npm:@howaboua/pi-subagent-review",
    "npm:@eko24ive/pi-ask"
  ],
  "defaultProvider": "cf-compat",
  "defaultModel": "custom-opencode/deepseek-v4-pro",
  "defaultThinkingLevel": "medium",
  "hideThinkingBlock": true,
  "terminal": {
    "showImages": true
  },
  "images": {
    "blockImages": false
  },
  "showHardwareCursor": false,
  "editorPaddingX": 0,
  "quietStartup": false,
  "compaction": {
    "enabled": true
  },
  "enabledModels": [
    "cf-compat/custom-synthetic/hf:zai-org/GLM-5.1",
    "cf-compat/custom-opencode/deepseek-v4-pro",
    "cf-codex/gpt-5.5",
    "cf-codex/gpt-5.4-mini"
  ],
  "extensions": [
    "+extensions/pi-custom-providers/custom-provider-cf-packycode.ts"
  ],
  "subagents": {
    "agentOverrides": {
      "context-builder": {
        "model": "cf-compat/custom-synthetic/hf:moonshotai/Kimi-K2.5"
      },
      "oracle-executor": {
        "model": "cf-packycode/gpt-5.4"
      },
      "oracle": {
        "model": "cf-codex/gpt-5.4"
      },
      "planner": {
        "model": "cf-codex/gpt-5.5",
        "thinking": "medium"
      },
      "researcher": {
        "model": "cf-compat/custom-synthetic/hf:zai-org/GLM-4.7-Flash"
      },
      "reviewer": {
        "model": "cf-codex/gpt-5.5",
        "thinking": "medium"
      },
      "scout": {
        "model": "cf-compat/custom-synthetic/hf:moonshotai/Kimi-K2.5"
      },
      "worker": {
        "model": "cf-compat/custom-synthetic/hf:zai-org/GLM-5.1"
      }
    }
  }
}