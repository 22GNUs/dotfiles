{
  "lastChangelogVersion": "0.58.3",
  "theme": "tokyo-night",
  "packages": [
    "npm:checkpoint-pi",
    {
      "source": "git:github.com/22GNUs/agent-stuff.git",
      "extensions": [
        "pi-extensions/answer.ts",
        "pi-extensions/context.ts",
        "-pi-extensions/prompt-editor.ts",
        "-pi-extensions/todos.ts"
      ],
      "skills": [
        "skills/commit",
        "+skills/librarian/SKILL.md",
        "+skills/mermaid/SKILL.md"
      ],
      "themes": [],
      "prompts": [
        "-commands/execute-plan.md",
        "-commands/plan.md"
      ]
    },
    "git:github.com/22GNUs/pi-qwencode-auth.git"
  ],
  "defaultProvider": "github-copilot",
  "defaultModel": "gpt-5.1",
  "defaultThinkingLevel": "high",
  "hideThinkingBlock": false,
  "terminal": {
    "showImages": true
  },
  "images": {
    "blockImages": false
  },
  "showHardwareCursor": false,
  "editorPaddingX": 0,
  "quietStartup": false,
  "compaction": {
    "enabled": false
  },
  "enabledModels": [
    "github-copilot/claude-sonnet-4.6",
    "cf-packycode-sub/gpt-5.4-fast",
    "cf-compat/custom-chutes/zai-org/GLM-5-Turbo"
  ]
}