{
  "lastChangelogVersion": "0.74.0",
  "theme": "cyber-ui-dark",
  "packages": [
    "npm:pi-cyber-ui@0.1.6",
    "npm:pi-web-access",
    "npm:@sting8k/pi-vcc",
    "npm:@tmustier/pi-usage-extension",
    "npm:pi-caveman",
    "npm:@eko24ive/pi-ask",
    "npm:pi-btw",
    "git:github.com/edxeth/pi-openai-ws",
    {
      "source": "npm:pi-slop-review",
      "extensions": [
        "+extensions/pi/index.ts"
      ]
    },
    "npm:pi-rtk-optimizer"
  ],
  "defaultProvider": "cf-compat",
  "defaultModel": "custom-synthetic/hf:moonshotai/Kimi-K2.6",
  "defaultThinkingLevel": "low",
  "hideThinkingBlock": true,
  "terminal": {
    "showImages": true
  },
  "images": {
    "blockImages": false
  },
  "quietStartup": false,
  "compaction": {
    "enabled": true
  },
  "enabledModels": [
    "cf-compat/custom-synthetic/hf:zai-org/GLM-5.1",
    "cf-compat/custom-synthetic/hf:moonshotai/Kimi-K2.6",
    "cf-codex/gpt-5.5",
    "cf-compat/custom-opencode/deepseek-v4-pro"
  ],
  "extensions": [
    "+extensions/pi-custom-providers/custom-provider-cf-packycode.ts",
    "+extensions/pi-custom-providers/custom-provider-cliproxyapi.ts"
  ],
  "transport": "auto",
  "rewind": {
    "silentCheckpoints": false,
    "retention": {
      "maxSnapshots": 100,
      "maxAgeDays": 1,
      "scanMode": "ancestor-only",
      "pinLabeledEntries": true,
      "startupBudgetMs": 100
    }
  }
}