{
  "lastChangelogVersion": "0.66.1",
  "theme": "cyber-ui-dark",
  "packages": [
    "npm:pi-cyber-ui",
    "npm:@plannotator/pi-extension",
    "npm:pi-peon-ping"
  ],
  "defaultProvider": "github-copilot",
  "defaultModel": "gpt-5.4-mini",
  "defaultThinkingLevel": "high",
  "hideThinkingBlock": true,
  "terminal": {
    "showImages": true
  },
  "images": {
    "blockImages": false
  },
  "showHardwareCursor": false,
  "editorPaddingX": 0,
  "quietStartup": false,
  "compaction": {
    "enabled": true
  },
  "enabledModels": [
    "github-copilot/gpt-5.4-mini",
    "github-copilot/gpt-5.4",
    "github-copilot/claude-sonnet-4.6",
    "kimi-coding/k2p5"
  ],
  "extensions": [
    "-extensions/pi-custom-providers/custom-provider-cf-packycode.ts",
    "-extensions/pi-custom-providers/custom-provider-cf-packycode-aws.ts"
  ],
  "answerModel": "cf-compat/openrouter/stepfun/step-3.5-flash:free"
}