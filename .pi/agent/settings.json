  "transport": "auto",
  "rewind": {
    "silentCheckpoints": false,
    "retention": {
      "maxSnapshots": 100,
      "maxAgeDays": 1,
      "scanMode": "ancestor-only",
      "pinLabeledEntries": true,
      "startupBudgetMs": 100
    }
  }
