{
  "lastChangelogVersion": "0.74.1",
  "theme": "cyber-ui-dark",
  "packages": [
    "npm:pi-cyber-ui@0.1.15",
    "npm:pi-web-access",
    "npm:@tmustier/pi-usage-extension",
    "npm:pi-caveman",
    "npm:@eko24ive/pi-ask",
    {
      "source": "npm:pi-slop-review",
      "extensions": ["+extensions/pi/index.ts"]
    },
    "npm:pi-rtk-optimizer",
    {
      "source": "npm:@plannotator/pi-extension",
      "skills": []
    },
    "npm:pi-btw"
  ],
  "defaultProvider": "cf-codex",
  "defaultModel": "gpt-5.5",
  "defaultThinkingLevel": "low",
  "hideThinkingBlock": true,
  "terminal": {
    "showImages": false
  },
  "images": {
    "blockImages": false
  },
  "quietStartup": false,
  "compaction": {
    "enabled": true
  },
  "enabledModels": [
    "cf-codex/gpt-5.5",
    "cf-codex/gpt-5.4",
    "cf-codex/gpt-5.4-mini"
  ],
  "extensions": [
    "+extensions/pi-custom-providers/custom-provider-cf-packycode.ts",
    "+extensions/pi-custom-providers/custom-provider-cliproxyapi.ts"
  ],
  "transport": "auto",
  "rewind": {
    "silentCheckpoints": false,
    "retention": {
      "maxSnapshots": 100,
      "maxAgeDays": 1,
      "scanMode": "ancestor-only",
      "pinLabeledEntries": true,
      "startupBudgetMs": 100
    }
  }
}

