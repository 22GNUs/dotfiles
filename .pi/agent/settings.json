{
  "lastChangelogVersion": "0.80.9",
  "theme": "cyber-ui-dark",
  "externalEditor": "nvim",
  "packages": [
    "npm:pi-web-access",
    "npm:@eko24ive/pi-ask",
    "npm:@juicesharp/rpiv-todo",
    "npm:@aliou/pi-synthetic",
    "npm:@mohndoe/pi-atlas",
    "/Users/xinhua/Developer/pi-qoder-provider-inner",
    "/Users/xinhua/Developer/pi-cyber-ui"
  ],
  "defaultProvider": "cliproxy",
  "defaultModel": "grok-4.3",
  "defaultThinkingLevel": "low",
  "hideThinkingBlock": true,
  "terminal": {
    "showImages": false
  },
  "images": {
    "blockImages": false
  },
  "quietStartup": false,
  "compaction": {
    "enabled": true
  },
  "enabledModels": [
    "qoder/gm51model",
    "qoder/kmodel-highspeed",
    "synthetic/syn:large:text",
    "cliproxy/gpt-5.6-sol",
    "cliproxy/gpt-5.6-terra",
    "cliproxy/grok-4.3",
    "qoder/kmodel_latest"
  ],
  "extensions": [
    "+extensions/pi-custom-providers/custom-provider-cf-packycode.ts",
    "+extensions/pi-custom-providers/custom-provider-cliproxyapi.ts"
  ],
  "transport": "websocket-cached",
  "rewind": {
    "silentCheckpoints": false,
    "retention": {
      "maxSnapshots": 100,
      "maxAgeDays": 1,
      "scanMode": "ancestor-only",
      "pinLabeledEntries": true,
      "startupBudgetMs": 100
    }
  },
  "defaultProjectTrust": "always"
}