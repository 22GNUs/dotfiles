{
  "lastChangelogVersion": "0.75.3",
  "theme": "cyber-ui-dark",
  "packages": [
    "npm:pi-cyber-ui@0.1.21",
    "npm:pi-web-access",
    "npm:@tmustier/pi-usage-extension",
    "npm:pi-caveman",
    "npm:@eko24ive/pi-ask",
    "npm:pi-slop-review",
    "npm:pi-rtk-optimizer",
    "npm:pi-btw",
    {
      "source": "npm:@plannotator/pi-extension",
      "skills": []
    }
  ],
  "defaultProvider": "cf-codex",
  "defaultModel": "gpt-5.5",
  "defaultThinkingLevel": "minimal",
  "hideThinkingBlock": true,
  "terminal": {
    "showImages": false
  },
  "images": {
    "blockImages": false
  },
  "quietStartup": false,
  "compaction": {
    "enabled": true
  },
  "enabledModels": [
    "cf-codex/gpt-5.5",
    "cf-codex/gpt-5.4-mini",
    "cf-compat/openrouter/deepseek/deepseek-v4-pro"
  ],
  "extensions": [
    "+extensions/pi-custom-providers/custom-provider-cf-packycode.ts",
    "+extensions/pi-custom-providers/custom-provider-cliproxyapi.ts"
  ],
  "transport": "auto",
  "rewind": {
    "silentCheckpoints": false,
    "retention": {
      "maxSnapshots": 100,
      "maxAgeDays": 1,
      "scanMode": "ancestor-only",
      "pinLabeledEntries": true,
      "startupBudgetMs": 100
    }
  }
}