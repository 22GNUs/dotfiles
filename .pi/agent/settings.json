{
  "lastChangelogVersion": "0.55.3",
  "theme": "tokyo-night",
  "packages": [
    "npm:checkpoint-pi",
    {
      "source": "git:github.com/22GNUs/agent-stuff.git",
      "extensions": [
        "pi-extensions/answer.ts",
        "pi-extensions/todos.ts",
        "pi-extensions/context.ts"
      ],
      "skills": ["skills/commit"],
      "themes": []
    }
  ],
  "defaultProvider": "cf-compat",
  "defaultModel": "openrouter/deepseek/deepseek-v3.2",
  "defaultThinkingLevel": "minimal",
  "hideThinkingBlock": false,
  "terminal": {
    "showImages": true
  },
  "images": {
    "blockImages": false
  },
  "showHardwareCursor": false,
  "editorPaddingX": 0,
  "quietStartup": false,
  "compaction": {
    "enabled": false
  }
}
