{
  "lastChangelogVersion": "0.70.2",
  "theme": "cyber-ui-dark",
  "packages": [
    "npm:pi-cyber-ui@0.1.2",
    "npm:pi-web-access",
    "npm:pi-subagents",
    "npm:pi-peon-ping",
    "npm:@plannotator/pi-extension",
    "npm:@sting8k/pi-vcc",
    "git:github.com/fluxgear/pi-thinking-steps",
    "npm:pi-rtk-optimizer",
    "npm:@tmustier/pi-usage-extension",
    "npm:pi-caveman"
  ],
  "defaultProvider": "cf-compat",
  "defaultModel": "custom-opencode/kimi-k2.6",
  "defaultThinkingLevel": "high",
  "hideThinkingBlock": false,
  "terminal": {
    "showImages": true
  },
  "images": {
    "blockImages": false
  },
  "showHardwareCursor": false,
  "editorPaddingX": 0,
  "quietStartup": false,
  "compaction": {
    "enabled": true
  },
  "enabledModels": [
    "cf-compat/custom-synthetic/hf:zai-org/GLM-5.1",
    "cf-compat/custom-opencode/kimi-k2.6",
    "cf-compat/custom-synthetic/hf:zai-org/GLM-4.7"
  ],
  "extensions": [
    "-extensions/pi-custom-providers/custom-provider-cf-packycode-aws.ts",
    "+extensions/pi-custom-providers/custom-provider-cf-packycode.ts"
  ],
  "subagents": {
    "agentOverrides": {
      "context-builder": {
        "model": "cf-compat/custom-opencode/kimi-k2.6"
      },
      "oracle-executor": {
        "model": "cf-packycode/gpt-5.4"
      },
      "oracle": {
        "model": "cf-packycode/gpt-5.4"
      },
      "planner": {
        "model": "cf-packycode/gpt-5.5"
      },
      "researcher": {
        "model": "cf-compat/custom-synthetic/hf:zai-org/GLM-4.7-Flash"
      },
      "reviewer": {
        "model": "cf-packycode/gpt-5.4"
      },
      "scout": {
        "model": "cf-compat/custom-opencode/kimi-k2.6"
      },
      "worker": {
        "model": "cf-compat/custom-opencode/kimi-k2.6"
      }
    }
  }
}