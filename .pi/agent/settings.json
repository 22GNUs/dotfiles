{
  "lastChangelogVersion": "0.67.68",
  "theme": "cyber-ui-dark",
  "packages": [
    "npm:pi-cyber-ui@0.1.2",
    "npm:pi-web-access",
    "npm:pi-subagents",
    "npm:pi-peon-ping",
    "npm:@plannotator/pi-extension",
    "npm:@sting8k/pi-vcc",
    "npm:pi-rtk-optimizer",
    "git:github.com/22GNUs/pi-kimi-full"
  ],
  "defaultProvider": "kimi-for-coding-oauth",
  "defaultModel": "kimi-for-coding",
  "defaultThinkingLevel": "high",
  "hideThinkingBlock": true,
  "terminal": {
    "showImages": true
  },
  "images": {
    "blockImages": false
  },
  "showHardwareCursor": false,
  "editorPaddingX": 0,
  "quietStartup": false,
  "compaction": {
    "enabled": true
  },
  "enabledModels": [
    "github-copilot/gpt-5.4",
    "github-copilot/claude-sonnet-4.6",
    "cf-compat/custom-synthetic/hf:zai-org/GLM-5.1",
    "kimi-for-coding-oauth/kimi-for-coding"
  ],
  "extensions": [
    "-extensions/pi-custom-providers/custom-provider-cf-packycode-aws.ts",
    "+extensions/pi-custom-providers/custom-provider-cf-packycode.ts"
  ]
}
