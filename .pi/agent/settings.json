{
  "lastChangelogVersion": "0.79.1",
  "theme": "cyber-ui-dark",
  "packages": [
    "/Users/xinhua/Developer/pi-cyber-ui",
    "npm:pi-web-access",
    "npm:@tmustier/pi-usage-extension",
    "npm:pi-caveman",
    "npm:@eko24ive/pi-ask",
    "npm:pi-slop-review"
