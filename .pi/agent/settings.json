{
  "lastChangelogVersion": "0.66.1",
  "theme": "cyber-ui-dark",
  "packages": [
    {
      "source": "npm:pi-cyber-ui",
      "extensions": [
        "+extensions/pi-cyber-ui/index.ts"
      ],
      "themes": [
        "+themes/cyber-ui-dark.json"
      ]
    },
    "npm:pi-web-access",
    "npm:pi-subagents",
    "npm:pi-peon-ping",
    "npm:@plannotator/pi-extension"
  ],
  "defaultProvider": "cf-compat",
  "defaultModel": "custom-synthetic/hf:nvidia/Kimi-K2.5-NVFP4",
  "defaultThinkingLevel": "high",
  "hideThinkingBlock": true,
  "terminal": {
    "showImages": true
  },
  "images": {
    "blockImages": false
  },
  "showHardwareCursor": false,
  "editorPaddingX": 0,
  "quietStartup": false,
  "compaction": {
    "enabled": true
  },
  "enabledModels": [
    "github-copilot/gpt-5.4",
    "github-copilot/claude-sonnet-4.6",
    "github-copilot/claude-opus-4.6",
    "kimi-coding/kimi-for-coding"
  ],
  "extensions": [
    "-extensions/pi-custom-providers/custom-provider-cf-packycode.ts",
    "-extensions/pi-custom-providers/custom-provider-cf-packycode-aws.ts"
  ]
}