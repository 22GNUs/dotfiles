  "defaultProvider": "qoder",
  "defaultModel": "gm51model",
  "defaultThinkingLevel": "high",
  "hideThinkingBlock": true,
  "terminal": {
    "showImages": false
  },
  "images": {
    "blockImages": false
  },
  "quietStartup": false,
  "compaction": {
    "enabled": true
  },
  "enabledModels": [
    "cf-codex/gpt-5.5",
    "cf-codex/gpt-5.4-mini",
    "cf-compat/deepseek/deepseek-v4-pro"
