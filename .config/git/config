[include]
  path = ~/.gitconfig.local

[core]
  editor = nvim
	pager = hunk pager
	untrackedCache = true
	fsmonitor = true
	preloadIndex = true

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true
  dark = true

[merge "mergiraf"]
    name = mergiraf
    driver = mergiraf merge --git %O %A %B -s %S -x %X -y %Y -p %P -l %L

[mergetool "ec"]
    cmd = ec "$BASE" "$LOCAL" "$REMOTE" "$MERGED"
    trustExitCode = true

[merge]
    tool = ec
    conflictStyle = zdiff3
[feature]
	manyFiles = true

[rerere]
	enabled = true
[index]
	threads = true
[pack]
	threads = 0
[checkout]
	workers = 0
	thresholdForParallelism = 100
[submodule]
	fetchJobs = 0
[fetch]
	parallel = 0
