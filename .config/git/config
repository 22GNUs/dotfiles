[include]
  path = ~/.gitconfig.local

[core]
  editor = nvim
  pager = delta
	untrackedCache = true

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true
  dark = true

[merge "mergiraf"]
    name = mergiraf
    driver = mergiraf merge --git %O %A %B -s %S -x %X -y %Y -p %P -l %L

[mergetool "ec"]
    cmd = ec "$BASE" "$LOCAL" "$REMOTE" "$MERGED"
    trustExitCode = true

[merge]
    tool = ec
    conflictStyle = zdiff3
[feature]
	manyFiles = true

[rerere]
	enabled = true
